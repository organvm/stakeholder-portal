{
  "name": "@organvm/hermeneus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:contracts": "npm run lint && npm run validate-manifest && npm run build && npm run ci:quality-gate",
    "eval:offline": "tsx scripts/run-evals.ts",
    "maintenance:run": "tsx scripts/run-maintenance.ts",
    "validate-manifest": "tsx scripts/validate-manifest.ts",
    "generate": "tsx src/lib/ingestion/ingest-worker.ts",
    "generate:incremental": "tsx src/lib/ingestion/ingest-worker.ts --incremental",
    "prebuild": "npm run generate -- --allow-stale-manifest --skip-vector && npm run validate-manifest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "ci:quality-gate": "tsx scripts/ci-quality-gate.ts",
    "escalation:seed": "tsx -e \"import('@/lib/alert-audit').then(m => m.seedEscalationPolicies()).then(() => console.log('Policies seeded.'))\"",
    "planning:seed": "tsx scripts/seed-planning.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@langchain/core": "1.2.0",
    "@langchain/textsplitters": "1.0.1",
    "drizzle-orm": "0.45.2",
    "langchain": "1.5.0",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.31",
    "pg": "8.22.0",
    "pgvector": "0.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "10.1.0",
    "yaml": "2.9.0"
  },
  "overrides": {
    "flatted": "https://github.com/WebReflection/flatted/archive/refs/tags/v3.4.2.tar.gz",
    "esbuild": "^0.25.12",
    "postcss": "8.5.15"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "26.0.0",
    "@types/pg": "8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "^6.0.3",
    "vitest": "4.1.9"
  }
}
